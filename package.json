{
  "name": "pretty-poly",
  "version": "0.3.0",
  "private": true,
  "description": "A shadcn/ui compatible polymorphic React component library for creating resizable, responsive grid layouts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pretty-poly/react-pretty-poly.git"
  },
  "bugs": "https://github.com/pretty-poly/react-pretty-poly/issues",
  "type": "module",
  "scripts": {
    "registry:validate": "shadcn registry validate ./registry.json",
    "update:demo": "cd examples/demo && npm run update:grid && npm run lint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "grid",
    "layout",
    "resizable",
    "responsive",
    "polymorphic",
    "typescript",
    "css-grid",
    "shadcn",
    "shadcn-ui",
    "tailwindcss",
    "tailwind"
  ],
  "author": "Amazing Team",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.55.1",
    "@tailwindcss/vite": "^4.1.13",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^0.34.0",
    "@vitest/ui": "^0.34.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.45.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "jsdom": "^27.0.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "shadcn": "^4.10.0",
    "tailwindcss": "^4.1.13",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.20.6",
    "typescript": "^5.0.2",
    "typescript-eslint": "^8.45.0",
    "vite": "^5.4.20",
    "vitest": "^0.34.0"
  },
  "dependencies": {
    "clsx": "^2.0.0",
    "tailwind-merge": "^3.3.1"
  }
}
